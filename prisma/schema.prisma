// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String              @id @default(cuid())
  email                String              @unique
  name                 String?
  image                String?
  password             String?
  plan                 Plan                @default(FREE)
  billingCycle         BillingCycle        @default(MONTHLY)
  credits              Int                 @default(20)
  stripeId             String?             @unique
  sector               String?
  referralCode         String?             @unique
  onboardingCompleted  Boolean             @default(false)
  onboardingStep       Int                 @default(0)
  trialEndsAt          DateTime?
  isLifetime           Boolean             @default(false)
  lifetimeTier         String?             // e.g. "tier1", "tier2", "tier3" (AppSumo stacking)
  language             String              @default("fr")
  brands               Brand[]
  accounts             Account[]
  sessions             Session[]
  creditUsages         CreditUsage[]
  scheduledScans       ScheduledScan[]
  scoreAlerts          ScoreAlert[]
  alerts               Alert[]
  referralsSent        Referral[]          @relation("ReferralsSent")
  referralReceived     Referral?           @relation("ReferralReceived")
  scoreObjectives      ScoreObjective[]
  webhookConfigs       WebhookConfig[]
  analyses             AnalysisResult[]
  notifications        Notification[]
  notificationPrefs    NotificationPreference?
  apiKeys              ApiKey[]
  apiUsage             ApiUsage[]
  whiteLabelConfig     WhiteLabelConfig?
  ownedTeams           Team[]              @relation("TeamOwner")
  teamMemberships      TeamMember[]
  sentInvites          TeamInvite[]        @relation("InviteSender")
  activityLogs         ActivityLog[]
  createdAt            DateTime            @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Brand {
  id              String            @id @default(cuid())
  name            String
  domain          String?
  keywords        String            @default("[]") // JSON array of strings
  sector          String?
  isCompetitor    Boolean           @default(false)
  parentBrandId   String?           // For tracked competitors: which brand detected them
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  scans           Scan[]
  competitors     Competitor[]
  scheduledScans  ScheduledScan[]
  scoreAlerts     ScoreAlert[]
  alerts          Alert[]
  positionHistory PositionHistory[]
  scoreObjectives ScoreObjective[]
  createdAt       DateTime          @default(now())
}

model Competitor {
  id      String @id @default(cuid())
  name    String
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])
}

model Scan {
  id          String       @id @default(cuid())
  brandId     String
  brand       Brand        @relation(fields: [brandId], references: [id])
  query       String
  results     ScanResult[]
  globalScore Int          @default(0)
  llmCount    Int          @default(0) // how many LLMs responded (for confidence score)
  createdAt   DateTime     @default(now())
}

model ScanResult {
  id             String       @id @default(cuid())
  scanId         String
  scan           Scan         @relation(fields: [scanId], references: [id])
  llm            LLM
  mentioned      Boolean
  position       Int?
  context        String?
  sentiment      Sentiment?
  sentimentScore Float?       // -1.0 (very negative) to +1.0 (very positive) — nuanced
  sentimentTone  String?      // "authoritative" | "casual" | "critical" | "enthusiastic" | "neutral"
  competitors    String       @default("[]") // JSON array of strings
  rawResponse    String
  score          Int          @default(0)   // per-LLM score (0-100)
  citations      Citation[]
}

// Citation tracking: a citation is a source URL the LLM referenced when mentioning the brand.
// Critical for SEO actionable recommendations.
model Citation {
  id           String     @id @default(cuid())
  scanResultId String
  scanResult   ScanResult @relation(fields: [scanResultId], references: [id], onDelete: Cascade)
  sourceUrl    String
  sourceTitle  String?
  sourceDomain String
  quote        String?    // The snippet from the source that was used
  position     Int?       // order of citation in the response
  createdAt    DateTime   @default(now())

  @@index([sourceDomain])
  @@index([scanResultId])
}

model CreditUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  action    String   // "scan" | "competitor_analysis" | "content_generation" | "auto_scan"
  details   String?
  createdAt DateTime @default(now())
}

model GeneratedContent {
  id        String   @id @default(cuid())
  userId    String
  brandId   String
  type      String   // "article" | "faq" | "press_release" | "comparison"
  title     String
  content   String
  createdAt DateTime @default(now())
}

model ScheduledScan {
  id        String    @id @default(cuid())
  brandId   String
  brand     Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  frequency String    // "weekly" | "biweekly" | "monthly"
  nextRunAt DateTime
  lastRunAt DateTime?
  enabled   Boolean   @default(true)
  createdAt DateTime  @default(now())
}

// Alerts: drift detection & competitor appeared
model ScoreAlert {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  type      String   // 'drift' | 'competitor_appeared'
  llm       String?
  message   String
  data      String   @default("{}") // JSON with extra context
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// User-defined veille alerts (threshold-based)
model Alert {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // 'score_below' | 'score_above' | 'no_mention' | 'competitor_spike'
  brandId   String?
  brand     Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  threshold Float?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Score history per LLM for trend charts
model PositionHistory {
  id      String   @id @default(cuid())
  brandId String
  brand   Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  score   Int
  llm     String   // 'CHATGPT' | 'CLAUDE' | 'PERPLEXITY' | 'GEMINI' | 'global'
  date    DateTime @default(now())
}

// Referral program
model Referral {
  id             String    @id @default(cuid())
  referrerId     String
  referrer       User      @relation("ReferralsSent", fields: [referrerId], references: [id])
  referredUserId String?   @unique
  referredUser   User?     @relation("ReferralReceived", fields: [referredUserId], references: [id])
  code           String    @unique
  usedAt         DateTime?
  rewardGranted  Boolean   @default(false)
  createdAt      DateTime  @default(now())
}

// Score objective tracker
model ScoreObjective {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandId     String
  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  targetScore Int
  targetDate  DateTime
  achieved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([userId, brandId])
}

// Webhook configurations (Agency plan)
model WebhookConfig {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String
  events    String   @default("[]") // JSON array: ["scan.completed", "alert.created"]
  secret    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Predefined query templates by sector
model QueryTemplate {
  id       String @id @default(cuid())
  sector   String
  query    String
  language String @default("fr")
  plan     String @default("all") // 'all' | 'pro' | 'agency'
}

model ActionPlan {
  id        String       @id @default(cuid())
  userId    String
  brandId   String
  items     ActionItem[]
  createdAt DateTime     @default(now())
}

model ActionItem {
  id                 String     @id @default(cuid())
  planId             String
  plan               ActionPlan @relation(fields: [planId], references: [id])
  title              String
  description        String
  impact             String
  difficulty         String
  done               Boolean    @default(false)
  dueDate            DateTime?
  steps              String     @default("[]") // JSON array of step strings
  codeSnippet        String?
  estimatedTime      String?
  actionType         String?    // "schema_org" | "faq" | "meta_description" | "og_tags" | "canonical" | "structured_data" | "content" | "generic"
  verificationStatus String?    // "implemented" | "partial" | "not_implemented"
  verifiedAt         DateTime?
}

model AnalysisResult {
  id        String   @id @default(cuid())
  userId    String
  brandId   String?
  type      String   // seo_audit, benchmark, authority_score, sentiment_deep, coverage_matrix, citation_analysis, content_optimizer, faq_generator, head_to_head, competitor_analysis, sector_watch, site_performance
  input     Json     // paramètres d'entrée (url, brandId, etc.)
  result    Json     // résultat complet
  credits   Int      // crédits dépensés
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([userId, brandId, type])
}

enum Plan {
  FREE
  STARTER
  PRO
  AGENCY
}

enum LLM {
  CHATGPT
  CLAUDE
  PERPLEXITY
  GEMINI
}

enum Sentiment {
  VERY_NEGATIVE
  NEGATIVE
  NEUTRAL
  POSITIVE
  VERY_POSITIVE
}

enum BillingCycle {
  MONTHLY
  ANNUAL
  LIFETIME
}

// In-app notification center (aggregator for all alert types)
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  link      String?          // internal URL to navigate to
  iconKey   String?          // "bell" | "trending_up" | "alert" | "trophy" ...
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

enum NotificationType {
  SCAN_COMPLETED
  ALERT_TRIGGERED
  COMPETITOR_APPEARED
  SCORE_DRIFT
  OBJECTIVE_REACHED
  CREDITS_LOW
  BILLING_ISSUE
  TEAM_INVITE
  REFERRAL_REWARD
  SYSTEM
}

model NotificationPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailEnabled   Boolean  @default(true)
  slackEnabled   Boolean  @default(false)
  slackWebhook   String?
  smsEnabled     Boolean  @default(false)
  smsNumber      String?
  digestFrequency String  @default("realtime") // "realtime" | "hourly" | "daily" | "weekly"
  scoreDropThreshold Int  @default(10) // notify if score drops by X points
  mutedUntil     DateTime?
  updatedAt      DateTime @updatedAt
}

// Public API: API keys with scoped permissions and rate limiting
model ApiKey {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String     @unique // sha256 hash of the raw key (never store raw)
  keyPrefix  String     // first 8 chars for display: "ak_live_xxxx"
  scopes     String     @default("[\"read\"]") // JSON array: ["read","write","admin"]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  usage      ApiUsage[]

  @@index([keyHash])
  @@index([userId])
}

// API usage tracking for billing and rate limiting
model ApiUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeyId  String?
  apiKey    ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  endpoint  String
  method    String
  status    Int
  latencyMs Int?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([apiKeyId, createdAt])
}

// White-label configuration per user (Agency plan)
model WhiteLabelConfig {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName     String?
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String?  // hex "#5B47E0"
  accentColor     String?
  customDomain    String?  @unique
  customDomainVerified Boolean @default(false)
  supportEmail    String?
  footerText      String?
  hideAirankBranding Boolean @default(false)
  customCss       String?
  updatedAt       DateTime @updatedAt
}

// Team / Workspace — for agencies and multi-user accounts
model Team {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  ownerId     String
  owner       User         @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     TeamMember[]
  invites     TeamInvite[]
  plan        Plan         @default(STARTER)
  seatLimit   Int          @default(5)
  createdAt   DateTime     @default(now())
}

model TeamMember {
  id        String     @id @default(cuid())
  teamId    String
  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      TeamRole   @default(VIEWER)
  createdAt DateTime   @default(now())

  @@unique([teamId, userId])
}

enum TeamRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
  CLIENT // read-only access to specific brands (white-label use case)
}

model TeamInvite {
  id         String   @id @default(cuid())
  teamId     String
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  email      String
  role       TeamRole @default(VIEWER)
  token      String   @unique
  invitedById String
  invitedBy  User     @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([email])
}

// Activity audit log for compliance and debugging
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // "brand.created" | "scan.run" | "team.invite" | etc.
  entity    String?  // "brand" | "scan" | "team"
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Webhook delivery log (for retry logic + debugging)
model WebhookDelivery {
  id           String   @id @default(cuid())
  webhookId    String   // references WebhookConfig.id
  event        String
  payload      Json
  status       String   // "pending" | "success" | "failed" | "retrying"
  statusCode   Int?
  attemptCount Int      @default(0)
  lastAttemptAt DateTime?
  nextAttemptAt DateTime?
  error        String?
  createdAt    DateTime @default(now())

  @@index([webhookId, createdAt])
  @@index([status, nextAttemptAt])
}

// Sector benchmark snapshots — real competitive intelligence
model SectorBenchmark {
  id        String   @id @default(cuid())
  sector    String
  brandName String
  llm       String   // "CHATGPT" | "CLAUDE" | "PERPLEXITY" | "GEMINI" | "global"
  score     Int
  mentions  Int      @default(0)
  snapshot  DateTime @default(now())

  @@index([sector, snapshot])
  @@index([sector, brandName])
}

// Saved filter / custom dashboard view
model DashboardView {
  id        String   @id @default(cuid())
  userId    String
  name      String
  config    Json     // widgets layout, filters, date ranges
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}
