// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String           @id @default(cuid())
  email                String           @unique
  name                 String?
  image                String?
  password             String?
  plan                 Plan             @default(FREE)
  credits              Int              @default(20)
  stripeId             String?          @unique
  sector               String?
  referralCode         String?          @unique
  onboardingCompleted  Boolean          @default(false)
  onboardingStep       Int              @default(0)
  brands               Brand[]
  accounts             Account[]
  sessions             Session[]
  creditUsages         CreditUsage[]
  scheduledScans       ScheduledScan[]
  scoreAlerts          ScoreAlert[]
  alerts               Alert[]
  referralsSent        Referral[]       @relation("ReferralsSent")
  referralReceived     Referral?        @relation("ReferralReceived")
  scoreObjectives      ScoreObjective[]
  webhookConfigs       WebhookConfig[]
  createdAt            DateTime         @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Brand {
  id              String            @id @default(cuid())
  name            String
  domain          String?
  keywords        String            @default("[]") // JSON array of strings
  sector          String?
  isCompetitor    Boolean           @default(false)
  parentBrandId   String?           // For tracked competitors: which brand detected them
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  scans           Scan[]
  competitors     Competitor[]
  scheduledScans  ScheduledScan[]
  scoreAlerts     ScoreAlert[]
  alerts          Alert[]
  positionHistory PositionHistory[]
  scoreObjectives ScoreObjective[]
  createdAt       DateTime          @default(now())
}

model Competitor {
  id      String @id @default(cuid())
  name    String
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])
}

model Scan {
  id          String       @id @default(cuid())
  brandId     String
  brand       Brand        @relation(fields: [brandId], references: [id])
  query       String
  results     ScanResult[]
  globalScore Int          @default(0)
  llmCount    Int          @default(0) // how many LLMs responded (for confidence score)
  createdAt   DateTime     @default(now())
}

model ScanResult {
  id          String    @id @default(cuid())
  scanId      String
  scan        Scan      @relation(fields: [scanId], references: [id])
  llm         LLM
  mentioned   Boolean
  position    Int?
  context     String?
  sentiment   Sentiment?
  competitors String    @default("[]") // JSON array of strings
  rawResponse String
  score       Int       @default(0)   // per-LLM score (0-100)
}

model CreditUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  action    String   // "scan" | "competitor_analysis" | "content_generation" | "auto_scan"
  details   String?
  createdAt DateTime @default(now())
}

model GeneratedContent {
  id        String   @id @default(cuid())
  userId    String
  brandId   String
  type      String   // "article" | "faq" | "press_release" | "comparison"
  title     String
  content   String
  createdAt DateTime @default(now())
}

model ScheduledScan {
  id        String    @id @default(cuid())
  brandId   String
  brand     Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  frequency String    // "weekly" | "biweekly" | "monthly"
  nextRunAt DateTime
  lastRunAt DateTime?
  enabled   Boolean   @default(true)
  createdAt DateTime  @default(now())
}

// Alerts: drift detection & competitor appeared
model ScoreAlert {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  type      String   // 'drift' | 'competitor_appeared'
  llm       String?
  message   String
  data      String   @default("{}") // JSON with extra context
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// User-defined veille alerts (threshold-based)
model Alert {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // 'score_below' | 'score_above' | 'no_mention' | 'competitor_spike'
  brandId   String?
  brand     Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  threshold Float?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Score history per LLM for trend charts
model PositionHistory {
  id      String   @id @default(cuid())
  brandId String
  brand   Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  score   Int
  llm     String   // 'CHATGPT' | 'CLAUDE' | 'PERPLEXITY' | 'GEMINI' | 'global'
  date    DateTime @default(now())
}

// Referral program
model Referral {
  id             String    @id @default(cuid())
  referrerId     String
  referrer       User      @relation("ReferralsSent", fields: [referrerId], references: [id])
  referredUserId String?   @unique
  referredUser   User?     @relation("ReferralReceived", fields: [referredUserId], references: [id])
  code           String    @unique
  usedAt         DateTime?
  rewardGranted  Boolean   @default(false)
  createdAt      DateTime  @default(now())
}

// Score objective tracker
model ScoreObjective {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandId     String
  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  targetScore Int
  targetDate  DateTime
  achieved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([userId, brandId])
}

// Webhook configurations (Agency plan)
model WebhookConfig {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String
  events    String   @default("[]") // JSON array: ["scan.completed", "alert.created"]
  secret    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Predefined query templates by sector
model QueryTemplate {
  id       String @id @default(cuid())
  sector   String
  query    String
  language String @default("fr")
  plan     String @default("all") // 'all' | 'pro' | 'agency'
}

enum Plan {
  FREE
  STARTER
  PRO
  AGENCY
}

enum LLM {
  CHATGPT
  CLAUDE
  PERPLEXITY
  GEMINI
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}
